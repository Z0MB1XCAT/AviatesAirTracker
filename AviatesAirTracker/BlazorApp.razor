@using AviatesAirTracker.Shared

<Router AppAssembly="@typeof(BlazorApp).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <div class="empty-state" style="max-width:480px;margin:var(--sp-8) auto;">
                <div class="empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M22 16.5L13 3l-2 4-5-1L2 9l5 2-1 3 4 1 1 5 5-3z"/></svg></div>
                <div class="empty-title">Page Not Found</div>
                <div class="empty-sub">The page you're looking for doesn't exist. Check the navigation or return to the dashboard.</div>
                <a href="/" class="btn btn-primary">Return to Dashboard</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
