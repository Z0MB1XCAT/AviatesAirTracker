<UserControl x:Class="AviatesAirTracker.Views.MapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:AviatesAirTracker.ViewModels"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
             d:DataContext="{d:DesignInstance Type=vm:MapViewModel}"
             Background="{StaticResource Brush_BG_Primary}">
    <Grid>
        <!-- Full-bleed map -->
        <Border BorderThickness="0" ClipToBounds="True">
            <mapsui:MapControl x:Name="MapControl"/>
        </Border>

        <!-- Floating controls bar — glassmorphic overlay at bottom -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,20" CornerRadius="12" Padding="18,10">
            <Border.Background>
                <SolidColorBrush Color="#0D1220" Opacity="0.9"/>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF0A" Offset="0"/>
                    <GradientStop Color="#1A204008" Offset="0.5"/>
                    <GradientStop Color="#FFFFFF06" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <CheckBox Style="{StaticResource AviatesToggle}"
                          IsChecked="{Binding ShowPlannedRoute}"
                          Content="Planned Route" Margin="0,0,16,0"/>
                <CheckBox Style="{StaticResource AviatesToggle}"
                          IsChecked="{Binding ShowActualPath}"
                          Content="Actual Path" Margin="0,0,16,0"/>
                <CheckBox Style="{StaticResource AviatesToggle}"
                          IsChecked="{Binding ShowWaypoints}"
                          Content="Waypoints" Margin="0,0,16,0"/>

                <Border Width="1" Height="20" Background="#1A2040" Margin="0,0,16,0"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Aircraft " FontSize="11" Foreground="{StaticResource Brush_Text_Muted}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AircraftLat, StringFormat='{}{0:F4}'}" FontFamily="Cascadia Code, Consolas"
                               FontSize="11" Foreground="{StaticResource Brush_Accent_Light}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="N  " FontSize="9" Foreground="{StaticResource Brush_Text_Muted}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AircraftLon, StringFormat='{}{0:F4}'}" FontFamily="Cascadia Code, Consolas"
                               FontSize="11" Foreground="{StaticResource Brush_Accent_Light}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="E" FontSize="9" Foreground="{StaticResource Brush_Text_Muted}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Floating heading indicator — top right -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="0,16,16,0" CornerRadius="10" Padding="14,8">
            <Border.Background>
                <SolidColorBrush Color="#0D1220" Opacity="0.85"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="HDG " FontSize="10" Foreground="{StaticResource Brush_Text_Muted}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding AircraftHeading, StringFormat='{}{0:F0}°'}"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource Brush_Accent_Light}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>