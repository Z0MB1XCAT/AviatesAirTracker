<!-- SettingsView.xaml -->
<UserControl x:Class="AviatesAirTracker.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:AviatesAirTracker.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             Background="{StaticResource Brush_BG_Primary}">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="LenToVis" xmlns:converters="clr-namespace:AviatesAirTracker.Converters"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24" MaxWidth="720">

            <!-- Pilot Profile Section -->
            <TextBlock Text="Pilot Profile" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush_Text_Primary}"
                       Margin="0,0,0,10"/>

            <Border Style="{StaticResource AviatesCard}" Margin="0,0,0,20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="PILOT NAME" Style="{StaticResource TextStyle_CardLabel}"/>
                            <TextBox Style="{StaticResource AviatesTextBox}"
                                     Text="{Binding PilotName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PILOT ID" Style="{StaticResource TextStyle_CardLabel}"/>
                            <TextBox Style="{StaticResource AviatesTextBox}"
                                     Text="{Binding PilotId, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,14,0,0">
                        <TextBlock Text="ACARS KEY" Style="{StaticResource TextStyle_CardLabel}"/>
                        <TextBox Style="{StaticResource AviatesTextBox}" FontFamily="Cascadia Code, Consolas"
                                 Text="{Binding AcarsKey, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SimBrief Integration -->
            <TextBlock Text="SimBrief Integration" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush_Text_Primary}"
                       Margin="0,0,0,10"/>

            <Border Style="{StaticResource AviatesCard}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel>
                        <TextBlock Text="SIMBRIEF USERNAME" Style="{StaticResource TextStyle_CardLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource AviatesTextBox}"
                                     Text="{Binding SimBriefUsername, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Style="{StaticResource AviatesButton_Secondary}"
                                    Command="{Binding TestSimBriefCommand}" Padding="18,10">
                                <TextBlock Text="Test Connection" FontSize="12"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Margin="0,10,0,0"
                               Foreground="{StaticResource Brush_Accent_Light}"
                               Visibility="{Binding StatusMessage, Converter={StaticResource LenToVis}}"/>
                </StackPanel>
            </Border>

            <!-- Application Settings -->
            <TextBlock Text="Application Settings" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush_Text_Primary}"
                       Margin="0,0,0,10"/>

            <Border Style="{StaticResource AviatesCard}" Margin="0,0,0,20">
                <StackPanel>
                    <CheckBox Style="{StaticResource AviatesToggle}"
                              IsChecked="{Binding AutoConnect}"
                              Content="Auto-connect to MSFS on startup"/>
                    <CheckBox Style="{StaticResource AviatesToggle}"
                              IsChecked="{Binding ShowAlerts}"
                              Content="Show approach stability alerts"/>
                    <CheckBox Style="{StaticResource AviatesToggle}"
                              IsChecked="{Binding MinimizeToTray}"
                              Content="Minimize to system tray"/>
                </StackPanel>
            </Border>

            <!-- Save button -->
            <Button Style="{StaticResource AviatesButton_Primary}"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Left" Padding="32,12">
                <TextBlock Text="Save Settings" FontSize="13"/>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>