<UserControl x:Class="AviatesAirTracker.Views.ReplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:vm="clr-namespace:AviatesAirTracker.ViewModels"
             xmlns:converters="clr-namespace:AviatesAirTracker.Converters"
             d:DataContext="{d:DesignInstance Type=vm:ReplayViewModel}"
             Background="{StaticResource Brush_BG_Primary}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:BoolToPlayPauseTextConverter x:Key="PlayPauseTextConv"/>
    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="22"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Flight Selection -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Selected flight info -->
            <Border Grid.Row="0" Style="{StaticResource AviatesCard}">
                <Grid>
                    <Border CornerRadius="12" Opacity="0.5">
                        <Border.Background>
                            <RadialGradientBrush Center="0.2,0.3" RadiusX="0.8" RadiusY="0.8">
                                <GradientStop Color="#3B82F608" Offset="0"/>
                                <GradientStop Color="#3B82F600" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="SELECTED FLIGHT" Style="{StaticResource TextStyle_CardLabel}"/>
                        <TextBlock Text="{Binding SelectedFlightText}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush_Accent_Light}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Flight list -->
            <Border Grid.Row="2" Style="{StaticResource AviatesSectionCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource AviatesPanelHeader}">
                        <TextBlock Text="Available Flights" Style="{StaticResource TextStyle_SectionTitle}"/>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding AvailableFlights}"
                             Background="Transparent" BorderThickness="0"
                             SelectionChanged="FlightList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,10" Margin="4,2" CornerRadius="8" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0A3B82F6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DepartureICAO}"
                                                       FontFamily="Cascadia Code, Consolas" FontWeight="Bold"
                                                       FontSize="14" Foreground="{StaticResource Brush_Text_Primary}"/>
                                            <Border Margin="6,0" VerticalAlignment="Center" Width="16" Height="1"
                                                    Background="{StaticResource Brush_Text_Muted}"/>
                                            <TextBlock Text="{Binding ArrivalICAO}"
                                                       FontFamily="Cascadia Code, Consolas" FontWeight="Bold"
                                                       FontSize="14" Foreground="{StaticResource Brush_Text_Primary}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding TakeoffTime, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                       FontSize="10" Foreground="{StaticResource Brush_Text_Muted}" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding AircraftType}"
                                                       FontSize="10" Foreground="{StaticResource Brush_Text_Muted}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT: Replay Controls + Data -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Transport Controls — premium glass -->
            <Border Grid.Row="0" Style="{StaticResource AviatesCard}">
                <StackPanel>
                    <ProgressBar Style="{StaticResource AviatesProgressBar}"
                                 Value="{Binding ReplayPosition}" Maximum="100"
                                 Height="6" Foreground="{StaticResource Brush_Accent_Primary}"
                                 Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource AviatesButton_Ghost}"
                                    Command="{Binding StopCommand}" Width="42" Height="42">
                                <TextBlock Text="⏹" FontSize="16"/>
                            </Button>
                            <Button Style="{StaticResource AviatesButton_Primary}"
                                    Command="{Binding PlayPauseCommand}" Width="60" Height="42"
                                    Margin="6,0,16,0">
                                <TextBlock Text="{Binding IsReplaying, Converter={StaticResource PlayPauseTextConv}}"
                                           FontSize="16"/>
                            </Button>
                            <TextBlock Text="{Binding ReplayTimeText}" FontFamily="Cascadia Code, Consolas"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource Brush_Text_Primary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="SPEED" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush_Text_Muted}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                      />
                            <ComboBox Style="{StaticResource AviatesComboBox}" Width="80"
                                      SelectedValue="{Binding ReplaySpeed}">
                                <ComboBoxItem Content="1x" Tag="1"/>
                                <ComboBoxItem Content="2x" Tag="2"/>
                                <ComboBoxItem Content="4x" Tag="4"/>
                                <ComboBoxItem Content="8x" Tag="8"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Replay Metrics -->
            <UniformGrid Grid.Row="2" Columns="4">
                <Border Style="{StaticResource AviatesMetricCard}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="ALTITUDE" Style="{StaticResource TextStyle_CardLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ReplayAlt, StringFormat='{}{0:F0}'}"
                                       Style="{StaticResource TextStyle_MetricMedium}"
                                       Foreground="{StaticResource Brush_Accent_Light}"
                                       FontFamily="Cascadia Code, Consolas"/>
                            <TextBlock Text="ft" Style="{StaticResource TextStyle_Unit}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AviatesMetricCard}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="GROUND SPEED" Style="{StaticResource TextStyle_CardLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ReplaySpeed2, StringFormat='{}{0:F0}'}"
                                       Style="{StaticResource TextStyle_MetricMedium}"
                                       Foreground="{StaticResource Brush_Status_Cyan}"
                                       FontFamily="Cascadia Code, Consolas"/>
                            <TextBlock Text="kt" Style="{StaticResource TextStyle_Unit}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AviatesMetricCard}" Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="PHASE" Style="{StaticResource TextStyle_CardLabel}"/>
                        <TextBlock Text="{Binding ReplayPhase}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush_Text_Primary}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource AviatesMetricCard}">
                    <StackPanel>
                        <TextBlock Text="POSITION" Style="{StaticResource TextStyle_CardLabel}"/>
                        <TextBlock Text="{Binding ReplayPosition, StringFormat='{}{0:F0}%'}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush_Status_Purple}"
                                   FontFamily="Cascadia Code, Consolas"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Coordinate display — glass card -->
            <Border Grid.Row="4" Style="{StaticResource AviatesCard}">
                <StackPanel>
                    <TextBlock Text="REPLAY POSITION" Style="{StaticResource TextStyle_CardLabel}"
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="LAT" FontSize="9" Foreground="{StaticResource Brush_Text_Muted}"
                                      />
                            <TextBlock Text="{Binding ReplayLat, StringFormat='{}{0:F6}°'}"
                                       FontFamily="Cascadia Code, Consolas" FontSize="16"
                                       Foreground="{StaticResource Brush_Text_Primary}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="LON" FontSize="9" Foreground="{StaticResource Brush_Text_Muted}"
                                      />
                            <TextBlock Text="{Binding ReplayLon, StringFormat='{}{0:F6}°'}"
                                       FontFamily="Cascadia Code, Consolas" FontSize="16"
                                       Foreground="{StaticResource Brush_Text_Primary}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>