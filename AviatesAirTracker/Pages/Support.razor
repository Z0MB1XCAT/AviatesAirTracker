@page "/support"

<div class="page-header anim-up">
    <h1 class="page-title">Support</h1>
    <p class="page-sub">Get help, report issues, or connect with the AviatesAir community.</p>
</div>

<div class="card-grid-3 anim-up-d1" style="margin-bottom:var(--sp-6);">

    <div class="feature-card" style="text-align:center;">
        <div style="display:flex;justify-content:center;margin-bottom:var(--sp-4);">
            <div class="feature-icon blue" style="width:56px;height:56px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                </svg>
            </div>
        </div>
        <div class="feature-card-title">Live Chat</div>
        <div class="feature-card-sub">Chat directly with our operations staff or community members in real time.</div>
        <button class="btn btn-primary btn-sm" style="width:100%;">Open Chat</button>
    </div>

    <div class="feature-card" style="text-align:center;">
        <div style="display:flex;justify-content:center;margin-bottom:var(--sp-4);">
            <div class="feature-icon violet" style="width:56px;height:56px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                    <circle cx="12" cy="12" r="9"/><path d="M9.1 9a3 3 0 015.8 1c0 2-3 3-3 3M12 17h.01"/>
                </svg>
            </div>
        </div>
        <div class="feature-card-title">Knowledge Base</div>
        <div class="feature-card-sub">Browse guides on ACARS setup, flight filing, rank requirements, and more.</div>
        <button class="btn btn-ghost btn-sm" style="width:100%;">Browse Docs</button>
    </div>

    <div class="feature-card" style="text-align:center;">
        <div style="display:flex;justify-content:center;margin-bottom:var(--sp-4);">
            <div class="feature-icon cyan" style="width:56px;height:56px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/>
                </svg>
            </div>
        </div>
        <div class="feature-card-title">GitHub Issues</div>
        <div class="feature-card-sub">Report bugs or request features directly on our public GitHub repository.</div>
        <button class="btn btn-ghost btn-sm" style="width:100%;">Open GitHub</button>
    </div>

</div>

<!-- FAQ -->
<div class="anim-up-d2">
    <div class="section-header">
        <h2 class="section-title">Frequently Asked Questions</h2>
    </div>
    <div style="display:flex;flex-direction:column;gap:var(--sp-3);">
        @foreach (var faq in Faqs)
        {
            <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--r-xl);overflow:hidden;">
                <div style="padding:16px 20px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;"
                     @onclick="() => ToggleFaq(faq.Key)">
                    <div style="font-size:14px;font-weight:600;color:var(--text-primary);">@faq.Key</div>
                    <div style="color:var(--text-muted);font-size:18px;transform:@(OpenFaq == faq.Key ? "rotate(45deg)" : "rotate(0)");transition:transform 0.2s;">+</div>
                </div>
                @if (OpenFaq == faq.Key)
                {
                    <div style="padding:0 20px 16px;font-size:13.5px;color:var(--text-muted);line-height:1.6;border-top:1px solid var(--border-light);">
                        <div style="padding-top:12px;">@faq.Value</div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private string? OpenFaq;

    private void ToggleFaq(string key)
    {
        OpenFaq = OpenFaq == key ? null : key;
    }

    private Dictionary<string, string> Faqs = new()
    {
        { "How do I set up ACARS tracking?", "Go to Settings and enter your ACARS key. Then launch MSFS and load a flight — the tracker will connect automatically once SimConnect is active." },
        { "How is my landing score calculated?", "Your landing score is based on vertical speed at touchdown, pitch angle, bank angle, airspeed relative to Vref, crosswind component, and approach stability. Each factor contributes to a 0–100 score." },
        { "How do I advance my rank?", "Rank progression is based on logged block hours, number of completed flights, and average landing score. Visit Pilot Hub to see your current progress toward the next rank." },
        { "What aircraft types can I fly?", "You can fly any aircraft available in MSFS. The tracker records your aircraft type from SimConnect automatically. Some events may restrict to specific types." },
        { "How do I join a fly-in event?", "Visit the Events page and click Register on any upcoming event. You will receive details and a briefing packet via the in-app notification system." },
        { "Can I import a SimBrief OFP?", "Yes — go to Settings and enter your SimBrief Pilot ID. Then use the Import SimBrief button in the main header to load your active OFP before departure." }
    };
}
