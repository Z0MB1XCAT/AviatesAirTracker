@page "/events"
@inject EventsService EventsService
@inject SettingsService SettingsService

<div class="page-header anim-up">
    <h1 class="page-title">Events</h1>
    <p class="page-sub">Group fly-ins, competitions, and community gatherings across the AviatesAir network.</p>
</div>

@if (_statusMessage != null)
{
    <div class="events-status @(_isError ? "events-status-error" : "")" style="margin-bottom:var(--sp-4);">
        <span>@_statusMessage</span>
        <span class="events-status-close" @onclick="() => _statusMessage = null">×</span>
    </div>
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--sp-5);" class="anim-up-d1">
    <div class="tab-bar" style="margin-bottom:0;">
        <div class="tab-item @(_activeTab == "upcoming" ? "active" : "")" @onclick="TabUpcoming">Upcoming</div>
        <div class="tab-item @(_activeTab == "past"     ? "active" : "")" @onclick="TabPast">Past Events</div>
        <div class="tab-item @(_activeTab == "my"       ? "active" : "")" @onclick="TabMy">My Events</div>
    </div>
    <button class="btn btn-primary btn-sm" @onclick="OpenCreateModal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Create Event
    </button>
</div>

@if (_loading)
{
    <div style="text-align:center;padding:60px 0;color:var(--text-muted);">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="32" height="32"
             style="animation:spin 1s linear infinite;margin-bottom:12px;display:block;margin-left:auto;margin-right:auto;opacity:0.4;">
            <path d="M21 12a9 9 0 11-6.219-8.56"/>
        </svg>
        Loading events...
    </div>
}
else
{
    @if (_activeTab == "upcoming" && _featuredEvent != null)
    {
        <div class="hero-card anim-up-d1" style="min-height:160px;margin-bottom:var(--sp-5);">
            <div class="hero-content">
                <div class="hero-eyebrow">
                    <span class="hero-eyebrow-dot"></span>
                    Featured Event · @(_featuredEvent.ParsedDate?.ToString("MMMM yyyy") ?? "")
                </div>
                <h1 class="hero-title" style="font-size:24px;">@_featuredEvent.Title</h1>
                <p class="hero-sub" style="font-size:13px;margin-bottom:var(--sp-4);">@_featuredEvent.Description</p>
                <button class="hero-cta" style="font-size:12.5px;padding:9px 18px;"
                        @onclick="async () => await HandleRegister(_featuredEvent.Id, _featuredEvent.IsRegistered)">
                    @(_featuredEvent.IsRegistered ? "Unregister" : "Register Now")
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </button>
            </div>
            <div class="hero-art" style="width:200px;">
                <svg viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;">
                    <text x="80" y="120" font-size="80" fill="white" opacity="0.07">✈</text>
                    <circle cx="150" cy="50" r="15" stroke="rgba(59,130,246,0.25)" stroke-width="1"/>
                    <circle cx="150" cy="50" r="25" stroke="rgba(59,130,246,0.15)" stroke-width="1"/>
                    <circle cx="150" cy="50" r="35" stroke="rgba(59,130,246,0.08)" stroke-width="1"/>
                </svg>
            </div>
        </div>
    }

    @if (_events.Count == 0)
    {
        <div style="text-align:center;padding:60px 0;color:var(--text-muted);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48"
                 style="opacity:0.25;margin-bottom:16px;display:block;margin-left:auto;margin-right:auto;">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
            @if (_activeTab == "my")
            {
                <p style="font-size:13.5px;">
                    @(string.IsNullOrEmpty(SettingsService.Settings.AcarsKey)
                        ? "Set your ACARS key in Settings to view your registered events."
                        : "You haven't registered for any events yet.")
                </p>
            }
            else if (_activeTab == "past")
            {
                <p style="font-size:13.5px;">No past events found.</p>
            }
            else
            {
                <p style="font-size:13.5px;">No upcoming events at the moment. Check back soon!</p>
            }
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:var(--sp-3);" class="anim-up-d2">
            @foreach (var evt in _events)
            {
                <div class="event-card">
                    <div class="event-date-block">
                        <div class="event-day">@evt.DisplayDay</div>
                        <div class="event-month">@evt.DisplayMonth</div>
                    </div>
                    <div class="event-body">
                        <div style="display:flex;align-items:center;gap:var(--sp-2);margin-bottom:4px;flex-wrap:wrap;">
                            <div class="event-title" style="margin-bottom:0;">@evt.Title</div>
                            @if (evt.IsFeatured)
                            {
                                <span class="flight-chip chip-blue" style="font-size:10px;padding:2px 8px;">Featured</span>
                            }
                            @if (evt.IsRegistered)
                            {
                                <span class="flight-chip chip-green" style="font-size:10px;padding:2px 8px;">Registered</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(evt.Description))
                        {
                            <div class="event-desc">@evt.Description</div>
                        }
                        @if (!string.IsNullOrEmpty(evt.CreatedByName))
                        {
                            <div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;">By @evt.CreatedByName</div>
                        }
                        <div class="event-footer">
                            @if (!string.IsNullOrEmpty(evt.TimeUtc))
                            {
                                <div class="event-meta-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    @evt.TimeUtc UTC
                                </div>
                            }
                            <div class="event-meta-item">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                                @evt.RegistrationCount@(evt.MaxParticipants > 0 ? $"/{evt.MaxParticipants}" : "") registered
                            </div>
                            @if (!string.IsNullOrEmpty(evt.Route))
                            {
                                <div class="event-meta-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                    @evt.Route
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(evt.RankRestriction))
                            {
                                <span class="flight-chip chip-amber">@evt.RankRestriction</span>
                            }
                            @if (!string.IsNullOrEmpty(evt.AircraftRestriction))
                            {
                                <span class="flight-chip chip-violet">@evt.AircraftRestriction</span>
                            }
                            @if (_activeTab != "past")
                            {
                                var busy = _busyEvents.Contains(evt.Id);
                                var full = evt.MaxParticipants > 0 && evt.RegistrationCount >= evt.MaxParticipants && !evt.IsRegistered;
                                var capturedId = evt.Id;
                                var capturedReg = evt.IsRegistered;
                                @if (evt.IsRegistered)
                                {
                                    <button class="btn btn-ghost btn-sm"
                                            style="margin-left:auto;color:var(--red);"
                                            disabled="@busy"
                                            @onclick="async () => await HandleRegister(capturedId, true)">
                                        @(busy ? "..." : "Unregister")
                                    </button>
                                }
                                else if (full)
                                {
                                    <span class="flight-chip chip-orange" style="margin-left:auto;">Full</span>
                                }
                                else
                                {
                                    <button class="btn btn-primary btn-sm"
                                            style="margin-left:auto;"
                                            disabled="@busy"
                                            @onclick="async () => await HandleRegister(capturedId, false)">
                                        @(busy ? "..." : "Register")
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@if (_showCreateModal)
{
    <div class="modal-overlay" @onclick="CloseCreateModal">
        <div class="modal-panel" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 style="font-family:var(--font-display);font-size:17px;font-weight:700;color:var(--text-primary);">Create Event</h3>
                <button class="modal-close" @onclick="CloseCreateModal">×</button>
            </div>
            <div class="modal-body">
                @if (string.IsNullOrEmpty(SettingsService.Settings.AcarsKey))
                {
                    <div style="background:var(--amber-light);border:1px solid rgba(245,158,11,0.3);border-radius:var(--r-md);padding:12px 14px;font-size:13px;color:var(--amber);">
                        No ACARS key found. Go to Settings and enter your ACARS key before creating events.
                    </div>
                }
                <div class="form-group">
                    <label class="form-label">Title *</label>
                    <input class="form-input" @bind="_newEvent.Title" placeholder="Event name" maxlength="100" />
                </div>
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea class="form-input" @bind="_newEvent.Description" placeholder="What's this event about?" rows="3" maxlength="500" style="resize:vertical;"></textarea>
                </div>
                <div class="form-grid-2">
                    <div class="form-group">
                        <label class="form-label">Date *</label>
                        <input class="form-input" type="date"
                               value="@_newEvent.EventDate"
                               @onchange="@(e => _newEvent.EventDate = e.Value?.ToString() ?? string.Empty)" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Time (UTC)</label>
                        <input class="form-input" @bind="_newEvent.TimeUtc" placeholder="18:00" maxlength="10" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Route</label>
                    <input class="form-input" @bind="_newEvent.Route" placeholder="e.g. EGLL → KJFK" maxlength="100" />
                </div>
                <div class="form-grid-2">
                    <div class="form-group">
                        <label class="form-label">Aircraft Restriction</label>
                        <input class="form-input" @bind="_newEvent.AircraftRestriction" placeholder="e.g. A320 family" maxlength="100" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Rank Restriction</label>
                        <input class="form-input" @bind="_newEvent.RankRestriction" placeholder="e.g. Captain+ only" maxlength="100" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Max Participants <span style="font-weight:400;color:var(--text-muted);">(0 = unlimited)</span></label>
                    <input class="form-input" type="number" @bind="_newEvent.MaxParticipants" min="0" max="9999" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseCreateModal">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateEvent" disabled="@_creating">
                    @(_creating ? "Creating..." : "Create Event")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string _activeTab = "upcoming";
    private List<AviatesEvent> _events = [];
    private bool _loading = true;
    private string? _statusMessage;
    private bool _isError;
    private bool _showCreateModal;
    private CreateEventRequest _newEvent = new();
    private bool _creating;
    private readonly HashSet<int> _busyEvents = [];

    private AviatesEvent? _featuredEvent => _events.FirstOrDefault(e => e.IsFeatured);

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        _loading = true;
        StateHasChanged();

        var key = SettingsService.Settings.AcarsKey;

        _events = _activeTab switch
        {
            "past" => await EventsService.GetEventsAsync("past"),
            "my" when !string.IsNullOrEmpty(key) => await EventsService.GetMyEventsAsync(key),
            "my" => [],
            _ => await EventsService.GetEventsAsync("upcoming"),
        };

        _loading = false;
    }

    private Task TabUpcoming() => SwitchTab("upcoming");
    private Task TabPast()     => SwitchTab("past");
    private Task TabMy()       => SwitchTab("my");

    private async Task SwitchTab(string tab)
    {
        if (_activeTab == tab) return;
        _activeTab = tab;
        _statusMessage = null;
        await LoadEvents();
    }

    private void OpenCreateModal()
    {
        _newEvent = new();
        _showCreateModal = true;
    }

    private void CloseCreateModal()
    {
        _showCreateModal = false;
    }

    private async Task HandleRegister(int eventId, bool currentlyRegistered)
    {
        var key = SettingsService.Settings.AcarsKey;
        if (string.IsNullOrEmpty(key))
        {
            _statusMessage = "Set your ACARS key in Settings before registering for events.";
            _isError = true;
            return;
        }

        _busyEvents.Add(eventId);
        StateHasChanged();

        if (currentlyRegistered)
        {
            var (ok, err) = await EventsService.UnregisterFromEventAsync(eventId, key);
            _statusMessage = ok ? "Successfully unregistered." : err;
            _isError = !ok;
        }
        else
        {
            var (ok, err) = await EventsService.RegisterForEventAsync(eventId, key);
            _statusMessage = ok ? "Registered! See you there." : err;
            _isError = !ok;
        }

        _busyEvents.Remove(eventId);
        await LoadEvents();
    }

    private async Task CreateEvent()
    {
        var key = SettingsService.Settings.AcarsKey;
        if (string.IsNullOrEmpty(key))
        {
            _statusMessage = "Set your ACARS key in Settings first.";
            _isError = true;
            return;
        }
        if (string.IsNullOrWhiteSpace(_newEvent.Title))
        {
            _statusMessage = "Event title is required.";
            _isError = true;
            return;
        }
        if (string.IsNullOrWhiteSpace(_newEvent.EventDate))
        {
            _statusMessage = "Event date is required.";
            _isError = true;
            return;
        }

        _creating = true;
        StateHasChanged();

        var (ok, err) = await EventsService.CreateEventAsync(_newEvent, key);
        _creating = false;

        if (ok)
        {
            _showCreateModal = false;
            _newEvent = new();
            _statusMessage = "Event created! It's now live in Upcoming Events.";
            _isError = false;
            _activeTab = "upcoming";
            await LoadEvents();
        }
        else
        {
            _statusMessage = err;
            _isError = true;
            StateHasChanged();
        }
    }
}
