@page "/messages"
@inject MessagingService MessagingService
@inject SettingsService SettingsService
@implements IDisposable

<div class="page-header anim-up">
    <h1 class="page-title">Messages</h1>
    <p class="page-sub">Communicate with other AviatesAir pilots. All messages are moderated and tied to your ACARS key.</p>
</div>

@if (!_hasAcarsKey)
{
    <div class="msg-no-auth anim-up-d1">
        <div class="empty-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
        </div>
        <div class="empty-title">ACARS Key Required</div>
        <div class="empty-sub">Configure your ACARS key in Settings to use the messaging system.</div>
        <a href="/settings" class="btn btn-primary" style="text-decoration:none;">Go to Settings</a>
    </div>
}
else
{
    <!-- Tab bar -->
    <div class="msg-tabs anim-up-d1">
        <button class="msg-tab @(_activeTab == Tab.Inbox ? "active" : "")" @onclick="() => SwitchTab(Tab.Inbox)">
            Inbox
            @if (_unreadCount > 0)
            {
                <span class="msg-tab-badge">@_unreadCount</span>
            }
        </button>
        <button class="msg-tab @(_activeTab == Tab.Broadcast ? "active" : "")" @onclick="() => SwitchTab(Tab.Broadcast)">
            Broadcast
        </button>
        <button class="msg-tab @(_activeTab == Tab.Friends ? "active" : "")" @onclick="() => SwitchTab(Tab.Friends)">
            Friends
            @if (_friends.Count > 0)
            {
                <span class="msg-tab-count">@_friends.Count</span>
            }
        </button>
    </div>

    <!-- ── INBOX ── -->
    @if (_activeTab == Tab.Inbox)
    {
        <div class="msg-layout anim-up-d2">

            <!-- Friend list (left column) -->
            <div class="msg-friend-list">
                <div class="msg-friend-list-header">Direct Messages</div>
                @if (_friends.Count == 0)
                {
                    <div class="msg-friend-empty">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                            <circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 014-4h4a4 4 0 014 4v2"/>
                            <path d="M16 11l2 2 4-4"/>
                        </svg>
                        <span>Add friends to send direct messages</span>
                    </div>
                }
                @foreach (var friend in _friends)
                {
                    var unreadFromFriend = _inboxMessages.Count(m => m.SenderId == friend.PilotId && m.ReadAt == null);
                    <button class="msg-friend-item @(_selectedFriendId == friend.PilotId ? "active" : "")"
                            @onclick="() => SelectFriend(friend.PilotId)">
                        <div class="msg-friend-avatar">@GetInitials(friend.PilotName)</div>
                        <div class="msg-friend-info">
                            <div class="msg-friend-name">@friend.PilotName</div>
                            <div class="msg-friend-rank">@friend.Rank</div>
                        </div>
                        @if (unreadFromFriend > 0)
                        {
                            <span class="msg-unread-dot"></span>
                        }
                    </button>
                }
            </div>

            <!-- Conversation panel (right column) -->
            <div class="msg-conversation">
                @if (_selectedFriendId == null)
                {
                    <div class="msg-conversation-empty">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="36" height="36">
                            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                        </svg>
                        <span>Select a friend to start a conversation</span>
                    </div>
                }
                else
                {
                    var selectedFriend = _friends.FirstOrDefault(f => f.PilotId == _selectedFriendId);
                    var conversation   = GetConversation(_selectedFriendId);

                    <div class="msg-conv-header">
                        <div class="msg-friend-avatar small">@GetInitials(selectedFriend?.PilotName ?? "?")</div>
                        <div>
                            <div class="msg-conv-name">@(selectedFriend?.PilotName ?? "Pilot")</div>
                            <div class="msg-conv-rank">@(selectedFriend?.Rank ?? "")</div>
                        </div>
                        <button class="msg-remove-friend" title="Remove friend"
                                @onclick="() => RemoveFriend(_selectedFriendId)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                                <path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                            </svg>
                            Remove
                        </button>
                    </div>

                    <div class="msg-bubble-list" id="msg-bubble-list">
                        @if (!conversation.Any())
                        {
                            <div class="msg-conversation-empty small">No messages yet — say hello!</div>
                        }
                        @foreach (var msg in conversation)
                        {
                            var isMine = msg.SenderId == SettingsService.Settings.PilotId;
                            <div class="msg-bubble-wrap @(isMine ? "mine" : "theirs")">
                                <div class="msg-bubble @(isMine ? "mine" : "theirs")">
                                    <div class="msg-bubble-content">@msg.Content</div>
                                    <div class="msg-bubble-time">@FormatTime(msg.SentAt)</div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(_sendError))
                    {
                        <div class="msg-send-error">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            @_sendError
                        </div>
                    }
                    <div class="msg-compose">
                        <input class="msg-compose-input" type="text" placeholder="Type a message..."
                               @bind="_composeText" @bind:event="oninput"
                               @onkeydown="OnComposeKeyDown" maxlength="500" />
                        <button class="msg-send-btn" @onclick="SendDirect"
                                disabled="@(string.IsNullOrWhiteSpace(_composeText) || _isSending)">
                            @if (_isSending)
                            {
                                <span class="msg-sending-spinner"></span>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                                    <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                                </svg>
                            }
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    <!-- ── BROADCAST ── -->
    @if (_activeTab == Tab.Broadcast)
    {
        <div class="msg-broadcast-layout anim-up-d2">
            <div class="msg-broadcast-feed">
                <div class="msg-broadcast-header">
                    <span>AviatesAir Pilot Channel</span>
                    <span class="msg-broadcast-badge">Public</span>
                </div>
                <div class="msg-bubble-list broadcast">
                    @if (!_broadcastMessages.Any())
                    {
                        <div class="msg-conversation-empty small">No broadcasts yet. Be the first to post!</div>
                    }
                    @foreach (var msg in _broadcastMessages)
                    {
                        var isMine = msg.SenderId == SettingsService.Settings.PilotId;
                        <div class="msg-bubble-wrap @(isMine ? "mine" : "theirs")">
                            @if (!isMine)
                            {
                                <div class="msg-bubble-sender">@msg.SenderName</div>
                            }
                            <div class="msg-bubble @(isMine ? "mine" : "theirs")">
                                <div class="msg-bubble-content">@msg.Content</div>
                                <div class="msg-bubble-time">@FormatTime(msg.SentAt)</div>
                            </div>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_sendError))
                {
                    <div class="msg-send-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        @_sendError
                    </div>
                }
                <div class="msg-compose">
                    <input class="msg-compose-input" type="text" placeholder="Broadcast to all pilots..."
                           @bind="_broadcastText" @bind:event="oninput"
                           @onkeydown="OnBroadcastKeyDown" maxlength="280" />
                    <button class="msg-send-btn" @onclick="SendBroadcast"
                            disabled="@(string.IsNullOrWhiteSpace(_broadcastText) || _isSending)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- ── FRIENDS ── -->
    @if (_activeTab == Tab.Friends)
    {
        <div class="anim-up-d2" style="display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-5);align-items:start;">

            <!-- Add friend -->
            <div class="panel-card">
                <div class="form-section-title">Add a Pilot</div>
                <p style="font-size:13px;color:var(--text-muted);margin-bottom:var(--sp-4);line-height:1.6;">
                    Ask another pilot for their Friend Code (found in their Settings page) and enter it below.
                </p>
                <div class="form-group">
                    <label class="form-label">Friend Code</label>
                    <input class="form-input" type="text"
                           placeholder="e.g. K4MR-B7WN"
                           @bind="_addFriendCode" @bind:event="oninput"
                           maxlength="9" style="font-family:var(--font-mono);letter-spacing:0.08em;text-transform:uppercase;" />
                </div>
                <div class="form-group">
                    <label class="form-label">Pilot Name</label>
                    <input class="form-input" type="text"
                           placeholder="Their name (used if lookup is offline)"
                           @bind="_addFriendName" @bind:event="oninput"
                           maxlength="60" />
                </div>
                @if (!string.IsNullOrEmpty(_addFriendStatus))
                {
                    <div class="@(_addFriendError ? "msg-status-error" : "msg-status-ok")" style="margin-bottom:var(--sp-3);">
                        @_addFriendStatus
                    </div>
                }
                <button class="btn btn-primary" style="width:100%;justify-content:center;"
                        @onclick="AddFriend"
                        disabled="@(_addFriendCode.Length < 9 || _isAddingFriend)">
                    @if (_isAddingFriend)
                    {
                        <span class="msg-sending-spinner" style="border-color:#fff;border-top-color:transparent;"></span>
                        <span>Looking up pilot...</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15">
                            <circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 014-4h4a4 4 0 014 4v2"/>
                            <line x1="19" y1="8" x2="19" y2="14"/><line x1="16" y1="11" x2="22" y2="11"/>
                        </svg>
                        <span>Add Pilot</span>
                    }
                </button>
            </div>

            <!-- Friends list -->
            <div class="panel-card">
                <div class="form-section-title">Your Crew — @_friends.Count pilot@(_friends.Count == 1 ? "" : "s")</div>
                @if (_friends.Count == 0)
                {
                    <div style="text-align:center;padding:var(--sp-8) 0;">
                        <div style="font-size:13px;color:var(--text-muted);line-height:1.6;">
                            No friends added yet.<br/>Enter a Friend Code to get started.
                        </div>
                    </div>
                }
                else
                {
                    <div style="display:flex;flex-direction:column;gap:var(--sp-2);margin-top:var(--sp-2);">
                        @foreach (var friend in _friends)
                        {
                            <div class="msg-friends-row">
                                <div class="msg-friend-avatar small">@GetInitials(friend.PilotName)</div>
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:13.5px;font-weight:600;color:var(--text-primary);">@friend.PilotName</div>
                                    <div style="font-size:11.5px;color:var(--text-muted);">@friend.Rank · Added @friend.AddedAt.ToString("MMM d")</div>
                                </div>
                                <button class="btn btn-secondary" style="padding:5px 12px;font-size:12px;"
                                        @onclick="() => SelectFriendAndSwitchToInbox(friend.PilotId)">
                                    Message
                                </button>
                                <button class="msg-remove-friend icon-only" title="Remove friend"
                                        @onclick="() => RemoveFriend(friend.PilotId)">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                                        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/>
                                        <path d="M10 11v6M14 11v6M9 6V4h6v2"/>
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    private enum Tab { Inbox, Broadcast, Friends }
    private Tab _activeTab = Tab.Inbox;

    private List<PilotMessage> _inboxMessages     = [];
    private List<PilotMessage> _broadcastMessages = [];
    private List<FriendEntry>  _friends           = [];

    private string? _selectedFriendId;
    private string  _composeText    = "";
    private string  _broadcastText  = "";
    private string  _addFriendCode  = "";
    private string  _addFriendName  = "";
    private string  _addFriendStatus = "";
    private string? _sendError;
    private bool    _addFriendError;
    private bool    _isSending;
    private bool    _isAddingFriend;
    private int     _unreadCount;
    private bool    _hasAcarsKey;

    protected override async Task OnInitializedAsync()
    {
        _hasAcarsKey = !string.IsNullOrEmpty(SettingsService.Settings.AcarsKey);
        if (!_hasAcarsKey) return;

        MessagingService.NewMessageReceived += OnNewMessage;
        MessagingService.UnreadCountChanged += OnUnreadCountChanged;

        await RefreshAll();
    }

    private async Task RefreshAll()
    {
        _inboxMessages     = await MessagingService.GetInboxAsync();
        _broadcastMessages = await MessagingService.GetBroadcastsAsync();
        _friends           = await MessagingService.GetFriendsAsync();
        _unreadCount       = await MessagingService.GetUnreadCountAsync();
    }

    private void SwitchTab(Tab tab)
    {
        _activeTab       = tab;
        _addFriendStatus = "";
        _sendError       = null;
    }

    private void SelectFriend(string pilotId)
    {
        _selectedFriendId = pilotId;
        // Mark messages from this friend as read
        var unread = _inboxMessages.Where(m => m.SenderId == pilotId && m.ReadAt == null).ToList();
        foreach (var msg in unread)
            _ = MessagingService.MarkReadAsync(msg.Id);
        StateHasChanged();
    }

    private void SelectFriendAndSwitchToInbox(string pilotId)
    {
        _activeTab = Tab.Inbox;
        SelectFriend(pilotId);
    }

    private async Task SendDirect()
    {
        if (string.IsNullOrWhiteSpace(_composeText) || _selectedFriendId == null) return;
        _isSending  = true;
        _sendError  = null;
        var text    = _composeText;
        _composeText = "";
        StateHasChanged();

        var ok = await MessagingService.SendDirectAsync(_selectedFriendId, text);
        if (!ok)
        {
            _composeText = text; // restore so the pilot can edit and retry
            _sendError   = MessagingService.LastSendError ?? "Failed to send message.";
        }
        _inboxMessages = await MessagingService.GetInboxAsync();
        _isSending = false;
        StateHasChanged();
    }

    private async Task SendBroadcast()
    {
        if (string.IsNullOrWhiteSpace(_broadcastText)) return;
        _isSending     = true;
        _sendError     = null;
        var text       = _broadcastText;
        _broadcastText = "";
        StateHasChanged();

        var ok = await MessagingService.SendBroadcastAsync(text);
        if (!ok)
        {
            _broadcastText = text;
            _sendError     = MessagingService.LastSendError ?? "Failed to send broadcast.";
        }
        _broadcastMessages = await MessagingService.GetBroadcastsAsync();
        _isSending = false;
        StateHasChanged();
    }

    private async Task AddFriend()
    {
        if (_addFriendCode.Length < 9) return;
        _isAddingFriend  = true;
        _addFriendStatus = "";

        var entry = await MessagingService.AddFriendByCodeAsync(_addFriendCode, _addFriendName);
        if (entry != null)
        {
            _addFriendStatus = $"{entry.PilotName} added to your crew.";
            _addFriendError  = false;
            _addFriendCode   = "";
            _addFriendName   = "";
            _friends = await MessagingService.GetFriendsAsync();
        }
        else
        {
            _addFriendStatus = "Friend code not found. Check the code and try again.";
            _addFriendError  = true;
        }

        _isAddingFriend = false;
        StateHasChanged();
    }

    private async Task RemoveFriend(string? pilotId)
    {
        if (pilotId == null) return;
        await MessagingService.RemoveFriendAsync(pilotId);
        if (_selectedFriendId == pilotId) _selectedFriendId = null;
        _friends = await MessagingService.GetFriendsAsync();
        StateHasChanged();
    }

    private async Task OnComposeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await SendDirect();
    }

    private async Task OnBroadcastKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) await SendBroadcast();
    }

    private void OnNewMessage(object? sender, PilotMessage msg)
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshAll();
            StateHasChanged();
        });
    }

    private void OnUnreadCountChanged(object? sender, int count)
    {
        _ = InvokeAsync(() => { _unreadCount = count; StateHasChanged(); });
    }

    private List<PilotMessage> GetConversation(string friendId)
    {
        var myId = SettingsService.Settings.PilotId;
        return _inboxMessages
            .Where(m => (m.SenderId == friendId && m.RecipientId == myId) ||
                        (m.SenderId == myId && m.RecipientId == friendId))
            .OrderBy(m => m.SentAt)
            .ToList();
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        return string.Concat(
            name.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2)
                .Select(w => w[0]))
            .ToUpper();
    }

    private static string FormatTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalSeconds < 60)  return "just now";
        if (diff.TotalMinutes < 60)  return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours   < 24)  return $"{(int)diff.TotalHours}h ago";
        return dt.ToString("MMM d, HH:mm");
    }

    public void Dispose()
    {
        MessagingService.NewMessageReceived -= OnNewMessage;
        MessagingService.UnreadCountChanged -= OnUnreadCountChanged;
    }
}
