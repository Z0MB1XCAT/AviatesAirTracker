@page "/news"

<div class="page-header anim-up">
    <h1 class="page-title">News & Announcements</h1>
    <p class="page-sub">Stay up to date with AviatesAir operations, fleet updates, and community news.</p>
</div>

<div class="tab-bar anim-up-d1">
    <div class="tab-item active">All News</div>
    <div class="tab-item">Operations</div>
