<Window x:Class="AviatesAirTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AviatesAirTracker"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        Title="Aviates Air Flight Tracker"
        Height="900" Width="1440"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#060911"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Slim WPF title bar: drag + window controls only -->
            <RowDefinition Height="36"/>
            <!-- Blazor Hybrid fills the rest -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Minimal WPF Title Bar ── -->
        <Border Grid.Row="0"
                Background="#050810"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0A0F1E00" Offset="0"/>
                    <GradientStop Color="#1A2040" Offset="0.4"/>
                    <GradientStop Color="#1A2040" Offset="0.6"/>
                    <GradientStop Color="#0A0F1E00" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>0,0,0,1</Border.BorderThickness>
            <Grid>
                <!-- Window control buttons (right-aligned) -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0">
                    <!-- Minimize -->
                    <Button Width="36" Height="36" Click="MinimizeWindow"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Minimize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4" Width="36" Height="36">
                                    <TextBlock Text="—" FontSize="12"
                                               Foreground="#64748B" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A2040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Maximize / Restore -->
                    <Button Width="36" Height="36" Click="MaximizeWindow"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Maximize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4" Width="36" Height="36">
                                    <TextBlock Text="⬜" FontSize="10"
                                               Foreground="#64748B" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A2040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Close -->
                    <Button Width="36" Height="36" Click="CloseWindow"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4" Width="36" Height="36">
                                    <TextBlock Text="✕" FontSize="11"
                                               Foreground="#64748B" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#7F1D1D"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Blazor Hybrid WebView ── -->
        <blazor:BlazorWebView Grid.Row="1"
                              HostPage="wwwroot\index.html"
                              Services="{DynamicResource services}">
            <blazor:BlazorWebView.RootComponents>
                <blazor:RootComponent Selector="#app"
                                      ComponentType="{x:Type local:BlazorApp}"/>
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>
    </Grid>
</Window>
