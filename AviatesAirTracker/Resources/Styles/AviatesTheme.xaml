<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================
         AVIATES AIR BRAND COLOR PALETTE v2.0
         Premium glassmorphism dark theme with depth
         ================================================ -->

    <!-- Primary Backgrounds — deeper, richer tones -->
    <Color x:Key="BG_Primary">#060911</Color>
    <Color x:Key="BG_Secondary">#0B0F1A</Color>
    <Color x:Key="BG_Tertiary">#111627</Color>
    <Color x:Key="BG_Card">#0D1220</Color>
    <Color x:Key="BG_CardHover">#151C32</Color>
    <Color x:Key="BG_Sidebar">#080B16</Color>
    <Color x:Key="BG_Header">#070A13</Color>
    <Color x:Key="BG_Input">#0E1325</Color>
    <Color x:Key="BG_Elevated">#141A2E</Color>
    <Color x:Key="BG_Glass">#0D122080</Color>

    <!-- Border Colors — subtle glass edges -->
    <Color x:Key="Border_Primary">#1A2040</Color>
    <Color x:Key="Border_Accent">#243055</Color>
    <Color x:Key="Border_Focus">#3D7EEE</Color>
    <Color x:Key="Border_Glass">#FFFFFF0A</Color>
    <Color x:Key="Border_GlassHover">#FFFFFF14</Color>

    <!-- Aviates Blue Accent — refined -->
    <Color x:Key="Accent_Primary">#3B82F6</Color>
    <Color x:Key="Accent_Light">#60A5FA</Color>
    <Color x:Key="Accent_Dark">#2563EB</Color>
    <Color x:Key="Accent_Glow">#3B82F630</Color>
    <Color x:Key="Accent_Subtle">#3B82F615</Color>

    <!-- Status Colors — vibrant -->
    <Color x:Key="Status_Green">#22C55E</Color>
    <Color x:Key="Status_Yellow">#FACC15</Color>
    <Color x:Key="Status_Red">#EF4444</Color>
    <Color x:Key="Status_Orange">#F97316</Color>
    <Color x:Key="Status_Cyan">#06B6D4</Color>
    <Color x:Key="Status_Purple">#A78BFA</Color>
    <Color x:Key="Status_Pink">#F472B6</Color>
    <Color x:Key="Status_Emerald">#34D399</Color>

    <!-- Text Colors — better hierarchy -->
    <Color x:Key="Text_Primary">#F1F5F9</Color>
    <Color x:Key="Text_Secondary">#94A3B8</Color>
    <Color x:Key="Text_Muted">#475569</Color>
    <Color x:Key="Text_Accent">#60A5FA</Color>
    <Color x:Key="Text_Success">#4ADE80</Color>
    <Color x:Key="Text_Warning">#FACC15</Color>
    <Color x:Key="Text_Error">#F87171</Color>
    <Color x:Key="Text_Dimmed">#334155</Color>

    <!-- SolidColorBrush versions -->
    <SolidColorBrush x:Key="Brush_BG_Primary" Color="{StaticResource BG_Primary}"/>
    <SolidColorBrush x:Key="Brush_BG_Secondary" Color="{StaticResource BG_Secondary}"/>
    <SolidColorBrush x:Key="Brush_BG_Tertiary" Color="{StaticResource BG_Tertiary}"/>
    <SolidColorBrush x:Key="Brush_BG_Card" Color="{StaticResource BG_Card}"/>
    <SolidColorBrush x:Key="Brush_BG_Sidebar" Color="{StaticResource BG_Sidebar}"/>
    <SolidColorBrush x:Key="Brush_BG_Header" Color="{StaticResource BG_Header}"/>
    <SolidColorBrush x:Key="Brush_BG_Input" Color="{StaticResource BG_Input}"/>
    <SolidColorBrush x:Key="Brush_BG_Elevated" Color="{StaticResource BG_Elevated}"/>
    <SolidColorBrush x:Key="Brush_Border_Primary" Color="{StaticResource Border_Primary}"/>
    <SolidColorBrush x:Key="Brush_Border_Accent" Color="{StaticResource Border_Accent}"/>
    <SolidColorBrush x:Key="Brush_Border_Focus" Color="{StaticResource Border_Focus}"/>
    <SolidColorBrush x:Key="Brush_Accent_Primary" Color="{StaticResource Accent_Primary}"/>
    <SolidColorBrush x:Key="Brush_Accent_Light" Color="{StaticResource Accent_Light}"/>
    <SolidColorBrush x:Key="Brush_Accent_Dark" Color="{StaticResource Accent_Dark}"/>
    <SolidColorBrush x:Key="Brush_Status_Green" Color="{StaticResource Status_Green}"/>
    <SolidColorBrush x:Key="Brush_Status_Yellow" Color="{StaticResource Status_Yellow}"/>
    <SolidColorBrush x:Key="Brush_Status_Red" Color="{StaticResource Status_Red}"/>
    <SolidColorBrush x:Key="Brush_Status_Orange" Color="{StaticResource Status_Orange}"/>
    <SolidColorBrush x:Key="Brush_Status_Cyan" Color="{StaticResource Status_Cyan}"/>
    <SolidColorBrush x:Key="Brush_Status_Purple" Color="{StaticResource Status_Purple}"/>
    <SolidColorBrush x:Key="Brush_Text_Primary" Color="{StaticResource Text_Primary}"/>
    <SolidColorBrush x:Key="Brush_Text_Secondary" Color="{StaticResource Text_Secondary}"/>
    <SolidColorBrush x:Key="Brush_Text_Muted" Color="{StaticResource Text_Muted}"/>
    <SolidColorBrush x:Key="Brush_Text_Accent" Color="{StaticResource Text_Accent}"/>

    <!-- ================================================
         GRADIENT BRUSHES — premium depth
         ================================================ -->

    <!-- Primary accent gradient with refined stops -->
    <LinearGradientBrush x:Key="Brush_Accent_Gradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2563EB" Offset="0"/>
        <GradientStop Color="#3B82F6" Offset="0.5"/>
        <GradientStop Color="#60A5FA" Offset="1"/>
    </LinearGradientBrush>

    <!-- Card glassmorphism gradient -->
    <LinearGradientBrush x:Key="Brush_Card_Gradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0D1220" Offset="0"/>
        <GradientStop Color="#0F162A" Offset="0.5"/>
        <GradientStop Color="#111B32" Offset="1"/>
    </LinearGradientBrush>

    <!-- Card glassmorphism with subtle light edge -->
    <LinearGradientBrush x:Key="Brush_Glass_Card" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF05" Offset="0"/>
        <GradientStop Color="#FFFFFF00" Offset="0.5"/>
        <GradientStop Color="#FFFFFF02" Offset="1"/>
    </LinearGradientBrush>

    <!-- Sidebar gradient — deeper -->
    <LinearGradientBrush x:Key="Brush_Sidebar_Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#080B16" Offset="0"/>
        <GradientStop Color="#060910" Offset="1"/>
    </LinearGradientBrush>

    <!-- Header gradient with subtle accent line -->
    <LinearGradientBrush x:Key="Brush_Header_Gradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#070A13" Offset="0"/>
        <GradientStop Color="#090D18" Offset="1"/>
    </LinearGradientBrush>

    <!-- Status gradients for cards/badges -->
    <LinearGradientBrush x:Key="Brush_Status_Green_Gradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#15803D" Offset="0"/>
        <GradientStop Color="#22C55E" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush_Score_Excellent" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#22C55E20" Offset="0"/>
        <GradientStop Color="#22C55E08" Offset="1"/>
    </LinearGradientBrush>

    <!-- Mesh-style radial gradients for backgrounds -->
    <RadialGradientBrush x:Key="Brush_Glow_Blue" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#3B82F618" Offset="0"/>
        <GradientStop Color="#3B82F600" Offset="1"/>
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="Brush_Glow_Cyan" Center="0.3,0.3" RadiusX="0.6" RadiusY="0.6">
        <GradientStop Color="#06B6D412" Offset="0"/>
        <GradientStop Color="#06B6D400" Offset="1"/>
    </RadialGradientBrush>

    <!-- Panel header glow -->
    <LinearGradientBrush x:Key="Brush_PanelHeader_Glow" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3B82F610" Offset="0"/>
        <GradientStop Color="#0D122000" Offset="0.6"/>
    </LinearGradientBrush>

    <!-- ================================================
         WINDOW STYLE
         ================================================ -->
    <Style x:Key="AviatesWindowStyle" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Brush_BG_Primary}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush_Text_Primary}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <!-- ================================================
         GLASSMORPHIC CARD STYLE — primary container
         ================================================ -->
    <Style x:Key="AviatesCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush_Card_Gradient}"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFFFFF0A" Offset="0"/>
                    <GradientStop Color="#1A204008" Offset="0.5"/>
                    <GradientStop Color="#FFFFFF06" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="0" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================
         METRIC CARD — Large data display tiles
         ================================================ -->
    <Style x:Key="AviatesMetricCard" TargetType="Border" BasedOn="{StaticResource AviatesCard}">
        <Setter Property="Padding" Value="20"/>
        <Setter Property="MinHeight" Value="110"/>
    </Style>

    <!-- ================================================
         SECTION CARD — Panel with header
         ================================================ -->
    <Style x:Key="AviatesSectionCard" TargetType="Border" BasedOn="{StaticResource AviatesCard}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <!-- ================================================
         PANEL HEADER STRIP — with accent glow
         ================================================ -->
    <Style x:Key="AviatesPanelHeader" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush_PanelHeader_Glow}"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#3B82F620" Offset="0"/>
                    <GradientStop Color="#1A204010" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="CornerRadius" Value="12,12,0,0"/>
    </Style>

    <!-- ================================================
         STATUS INDICATOR — with glow
         ================================================ -->
    <Style x:Key="AviatesStatusDot" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================
         PROGRESS BAR — refined with glow
         ================================================ -->
    <Style x:Key="AviatesProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="4"/>
        <Setter Property="Background" Value="#0F162A"/>
        <Setter Property="Foreground" Value="{StaticResource Brush_Accent_Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Height="{TemplateBinding Height}"/>
                        <Border x:Name="PART_Indicator"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                Height="{TemplateBinding Height}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{Binding Foreground.Color, RelativeSource={RelativeSource TemplatedParent}}" Offset="0"/>
                                    <GradientStop Color="{Binding Foreground.Color, RelativeSource={RelativeSource TemplatedParent}}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.4"
                                                  Color="{Binding Foreground.Color, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================
         SEPARATOR
         ================================================ -->
    <Style x:Key="AviatesSeparator" TargetType="Separator">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1A204000" Offset="0"/>
                    <GradientStop Color="#1A2040" Offset="0.5"/>
                    <GradientStop Color="#1A204000" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,8"/>
    </Style>

    <!-- ================================================
         SCROLL VIEWER — minimal sleek scrollbar
         ================================================ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="GridRoot" Width="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="0"/>
                        </Grid.RowDefinitions>
                        <RepeatButton x:Name="PART_LineUpButton"
                                      Grid.Row="0" Height="0" Opacity="0"
                                      Command="ScrollBar.LineUpCommand" Focusable="False"/>
                        <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                              Focusable="False" Opacity="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#243055"
                                                    CornerRadius="3"
                                                    Margin="1,2"
                                                    Opacity="0.6"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                              Focusable="False" Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                        <RepeatButton x:Name="PART_LineDownButton"
                                      Grid.Row="2" Height="0" Opacity="0"
                                      Command="ScrollBar.LineDownCommand" Focusable="False"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>